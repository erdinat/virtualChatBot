# ===== Sanal Öğretmen Asistanı - Ortam Değişkenleri =====
# Bu dosyayı .env olarak kopyalayın ve kendi API anahtarlarınızı girin.
# cp .env.example .env

# --- Güvenlik ---
# Güçlü rastgele değer üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=buraya-guclu-rastgele-deger-girin

# --- DeepSeek API ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Model Ayarları ---
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- RAG Ayarları ---
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVER_TOP_K=4
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vektör Veritabanı ---
VECTOR_STORE_PATH=data/vector_store

# --- Uygulama ---
APP_TITLE=Sanal Öğretmen Asistanı
APP_LANGUAGE=tr
DEBUG=false
